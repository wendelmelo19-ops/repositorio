// Online C compiler to run C program online
#include <stdio.h>
 
int main() {
    int senha;
 
    do {
        printf("Digite a senha: ");
        scanf("%d", &senha);
 
        if (senha != 1234) {
            printf("Senha incorreta! Tente novamente.\n");
        }
 
    } while (senha != 1234);
 
    printf("Acesso liberado!\n");
 
    return 0;
}

