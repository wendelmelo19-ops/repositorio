#include <stdio.h>
 
int main() {
    int i;
    float soma = 0;
    
    for (i = 1; i <= 10; i++) {
        if (i % 2 == 0) { // verifica se é par
            printf("%d\n", i);
            soma = soma + i;
        }
    }
 
    printf("Soma dos numeros positivos: %.2f\n", soma);
 
    return 0;
}