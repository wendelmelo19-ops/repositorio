#include <stdio.h>
 
int main() {
    int numero, total = 0, positivos = 0;
 
    printf("Digite um numero (0 para parar): ");
    scanf("%d", &numero);
 
    while (numero != 0) {
        total++;
 
        if (numero > 0) {
            positivos++;
        }
 
        printf("Digite um numero (0 para parar): ");
        scanf("%d", &numero);
    }
 
    printf("Total de numeros digitados: %d\n", total);
    printf("Quantidade de positivos: %d\n", positivos);
 
    return 0;
}