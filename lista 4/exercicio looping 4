// Online C compiler to run C program online
#include <stdio.h>

int main() {
   int i;
   int numero, contador = 0;
   float soma = 0; 
   
   for (i = 0; i < 10; i++){
       printf("digite o %d numero: ", i + 1);
       scanf("%d", &numero);
       if (numero > 50){
           contador++;
           soma = soma + numero;
       }
   }
   printf("quantidade de numeros maiores que 50: %d\n", contador);
   printf("soma desses numeros: %.2f\n", soma);
    return 0;
}